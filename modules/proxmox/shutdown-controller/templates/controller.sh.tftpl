#!/bin/sh
set -eu

PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"

STATE_DIR="/run/shutdown-controller"
DRY_RUN="${DRY_RUN:-true}"
POLL_INTERVAL_SECONDS="${POLL_INTERVAL_SECONDS:-15}"
STATUS_LOG_INTERVAL_SECONDS="${STATUS_LOG_INTERVAL_SECONDS:-0}"
NOOUT_MIN_RUNTIME_SECONDS="${NOOUT_MIN_RUNTIME_SECONDS:-1800}"
TALOS_SHUTDOWN_MIN_RUNTIME_SECONDS="${TALOS_SHUTDOWN_MIN_RUNTIME_SECONDS:-1200}"
LINUX_SHUTDOWN_MIN_RUNTIME_SECONDS="${LINUX_SHUTDOWN_MIN_RUNTIME_SECONDS:-1200}"
PROXMOX_SHUTDOWN_MIN_RUNTIME_SECONDS="${PROXMOX_SHUTDOWN_MIN_RUNTIME_SECONDS:-900}"
NUT_TARGET="${NUT_TARGET:-}"
CONTROLLER_NAME="${CONTROLLER_NAME:-shutdown-controller}"
KUBECTL_BIN="${KUBECTL_BIN:-/usr/local/bin/kubectl}"
TALOSCTL_BIN="${TALOSCTL_BIN:-/usr/local/bin/talosctl}"
SSH_BIN="${SSH_BIN:-ssh}"
UPSC_BIN="${UPSC_BIN:-upsc}"
JQ_BIN="${JQ_BIN:-jq}"
MQTT_PUB_BIN="${MQTT_PUB_BIN:-mosquitto_pub}"
MQTT_PORT="${MQTT_PORT:-1883}"
MQTT_CLIENT_ID="${MQTT_CLIENT_ID:-$CONTROLLER_NAME}"
MQTT_TOPIC_PREFIX="${MQTT_TOPIC_PREFIX:-homelab/$CONTROLLER_NAME}"
MQTT_RETAIN_STATUS="${MQTT_RETAIN_STATUS:-true}"
MQTT_DISCOVERY_PREFIX="${MQTT_DISCOVERY_PREFIX:-homeassistant}"
MQTT_ENABLE_HA_DISCOVERY="${MQTT_ENABLE_HA_DISCOVERY:-true}"
MQTT_DISCOVERY_REPUBLISH_INTERVAL_SECONDS="${MQTT_DISCOVERY_REPUBLISH_INTERVAL_SECONDS:-300}"
MQTT_SCHEMA_VERSION="${MQTT_SCHEMA_VERSION:-7}"
MQTT_DISCOVERY_SCHEMA_VERSION="${MQTT_DISCOVERY_SCHEMA_VERSION:-$MQTT_SCHEMA_VERSION}"
CONTROLLER_VERSION="${CONTROLLER_VERSION:-unknown}"
LOG_TO_CONSOLE="${LOG_TO_CONSOLE:-true}"
CONSOLE_DEVICE="${CONSOLE_DEVICE:-/dev/console}"
LOG_TO_FILE="${LOG_TO_FILE:-true}"
LOG_FILE="${LOG_FILE:-/var/log/shutdown-controller.log}"
RECOVERY_STATE_RESET_ON_LINE_POWER="${RECOVERY_STATE_RESET_ON_LINE_POWER:-true}"
LINUX_SHUTDOWN_TARGETS_B64="${LINUX_SHUTDOWN_TARGETS_B64:-}"
LINUX_SHUTDOWN_SSH_USER="${LINUX_SHUTDOWN_SSH_USER:-root}"
LINUX_SHUTDOWN_SSH_PORT="${LINUX_SHUTDOWN_SSH_PORT:-22}"
LINUX_SHUTDOWN_SSH_STRICT_HOST_KEY_CHECKING="${LINUX_SHUTDOWN_SSH_STRICT_HOST_KEY_CHECKING:-accept-new}"
LINUX_SHUTDOWN_SSH_KEY_PATH="${LINUX_SHUTDOWN_SSH_KEY_PATH:-/etc/shutdown-controller/linux-shutdown.key}"
LINUX_SHUTDOWN_SSH_KNOWN_HOSTS_PATH="${LINUX_SHUTDOWN_SSH_KNOWN_HOSTS_PATH:-/etc/shutdown-controller/known_hosts}"

mkdir -p "$STATE_DIR"

current_timestamp() {
	date -Iseconds
}

current_epoch() {
	date +%s
}

log() {
	timestamp="$(current_timestamp)"
	message="$timestamp shutdown-controller: $*"
	echo "$message"

	if [ "$LOG_TO_CONSOLE" = "true" ] && [ -w "$CONSOLE_DEVICE" ]; then
		printf '%s\n' "$message" >"$CONSOLE_DEVICE" 2>/dev/null || true
	fi

	if [ "$LOG_TO_FILE" = "true" ]; then
		log_dir="$(dirname "$LOG_FILE")"
		mkdir -p "$log_dir" 2>/dev/null || true
		printf '%s\n' "$message" >>"$LOG_FILE" 2>/dev/null || true
	fi
}

write_state_value() {
	name="$1"
	value="$2"
	printf '%s\n' "$value" >"$STATE_DIR/$name"
}

read_state_value() {
	name="$1"
	default_value="$2"
	if [ -f "$STATE_DIR/$name" ]; then
		cat "$STATE_DIR/$name" 2>/dev/null || printf '%s\n' "$default_value"
	else
		printf '%s\n' "$default_value"
	fi
}

delete_state_value() {
	rm -f "$STATE_DIR/$1"
}

marker_bool() {
	name="$1"
	if [ -f "$STATE_DIR/$name.done" ]; then
		printf '%s\n' "true"
	else
		printf '%s\n' "false"
	fi
}

controller_device_id() {
	printf '%s\n' "$CONTROLLER_NAME" | tr '.-' '__'
}

set_controller_phase() {
	write_state_value "controller.phase" "$1"
}

clear_shutdown_markers() {
	rm -f \
		"$STATE_DIR/talos_shutdown.done" \
		"$STATE_DIR/linux_shutdown.done" \
		"$STATE_DIR/proxmox_shutdown.done" \
		"$STATE_DIR/battery.stage"
}

clear_all_action_markers() {
	rm -f \
		"$STATE_DIR/ceph_noout.done" \
		"$STATE_DIR/talos_shutdown.done" \
		"$STATE_DIR/linux_shutdown.done" \
		"$STATE_DIR/proxmox_shutdown.done" \
		"$STATE_DIR/battery.stage"
}

reset_incident_state_for_new_event() {
	clear_all_action_markers
	write_state_value "recovery.status" "idle"
	write_state_value "recovery.blocker" ""
	write_state_value "recovery.elapsed_seconds" "0"
	write_state_value "incident.power_restored_at" ""
	write_state_value "incident.ended_at" ""
	write_state_value "incident.duration_seconds" "0"
	write_state_value "incident.trigger_reason" ""
	write_state_value "incident.trigger_status" ""
	write_state_value "incident.trigger_runtime" ""
	write_state_value "incident.trigger_charge" ""
	write_state_value "last_action" ""
	write_state_value "last_action_target" ""
	write_state_value "last_action_result" ""
	write_state_value "last_action_at" ""
}

format_seconds_hms() {
	seconds="$1"
	case "$seconds" in
		''|*[!0-9-]*)
			printf '%s\n' "unknown"
			return 0
			;;
		-*)
			printf '%s\n' "unknown"
			return 0
			;;
	esac

	hours=$((seconds / 3600))
	minutes=$(((seconds % 3600) / 60))
	remaining_seconds=$((seconds % 60))
	printf '%02d:%02d:%02d\n' "$hours" "$minutes" "$remaining_seconds"
}

duration_between_epochs() {
	start_epoch="$1"
	end_epoch="$2"
	case "$start_epoch" in
		''|*[!0-9]*) printf '%s\n' "0"; return 0 ;;
	esac
	case "$end_epoch" in
		''|*[!0-9]*) printf '%s\n' "0"; return 0 ;;
	esac
	if [ "$end_epoch" -lt "$start_epoch" ]; then
		printf '%s\n' "0"
		return 0
	fi
	printf '%s\n' $((end_epoch - start_epoch))
}

split_csv() {
	value="$1"
	old_ifs="$IFS"
	IFS=','
	set -- $value
	IFS="$old_ifs"
	for item in "$@"; do
		if [ -n "$item" ]; then
			printf '%s\n' "$item"
		fi
	done
}

normal_status_snapshot() {
	status="$1"
	incident_status="$(read_state_value "incident.status" "idle")"
	printf 'status=%s incident_status=%s\n' "$status" "$incident_status"
}

battery_action_stage() {
	runtime="$1"

	if [ "$runtime" -lt 0 ]; then
		printf '%s\n' "unknown"
		return 0
	fi

	if [ "$runtime" -le "$PROXMOX_SHUTDOWN_MIN_RUNTIME_SECONDS" ]; then
		printf '%s\n' "proxmox_shutdown"
		return 0
	fi

	if [ "$runtime" -le "$LINUX_SHUTDOWN_MIN_RUNTIME_SECONDS" ]; then
		printf '%s\n' "linux_shutdown"
		return 0
	fi

	if [ "$runtime" -le "$TALOS_SHUTDOWN_MIN_RUNTIME_SECONDS" ]; then
		printf '%s\n' "talos_shutdown"
		return 0
	fi

	if [ "$runtime" -le "$NOOUT_MIN_RUNTIME_SECONDS" ]; then
		printf '%s\n' "ceph_noout"
		return 0
	fi

	printf '%s\n' "monitoring"
}

controller_phase_for_status() {
	status="$1"
	runtime="$2"
	incident_status="$(read_state_value "incident.status" "idle")"

	if is_on_battery "$status"; then
		stage="$(battery_action_stage "$runtime")"
		if [ "$stage" = "monitoring" ] || [ "$stage" = "unknown" ]; then
			printf '%s\n' "on_battery"
			return 0
		fi
		printf '%s\n' "$stage"
		return 0
	fi

	case "$incident_status" in
		recovery_pending) printf '%s\n' "power_restored_recovery_pending" ;;
		timeout) printf '%s\n' "recovery_timeout" ;;
		recovered) printf '%s\n' "monitoring" ;;
		*) printf '%s\n' "monitoring" ;;
	esac
}

battery_status_snapshot() {
	status="$1"
	runtime="$2"
	charge="$3"
	stage="$(battery_action_stage "$runtime")"
	printf 'status=%s stage=%s charge=%s\n' "$status" "$stage" "$charge"
}

should_log_status() {
	snapshot="$1"
	prefix="$2"
	state_prefix="$STATE_DIR/$prefix"
	last_snapshot_file="${state_prefix}.snapshot"
	last_log_time_file="${state_prefix}.time"

	if [ ! -f "$last_snapshot_file" ] || [ ! -f "$last_log_time_file" ]; then
		return 0
	fi

	last_snapshot="$(cat "$last_snapshot_file" 2>/dev/null || true)"
	if [ "$snapshot" != "$last_snapshot" ]; then
		return 0
	fi

	case "$STATUS_LOG_INTERVAL_SECONDS" in
		''|*[!0-9]*) return 1 ;;
		0) return 1 ;;
	esac

	now="$(current_epoch)"
	last_log_time="$(cat "$last_log_time_file" 2>/dev/null || printf '0')"
	case "$last_log_time" in
		''|*[!0-9]*) return 0 ;;
	esac

	if [ $((now - last_log_time)) -ge "$STATUS_LOG_INTERVAL_SECONDS" ]; then
		return 0
	fi

	return 1
}

record_status_log() {
	snapshot="$1"
	prefix="$2"
	state_prefix="$STATE_DIR/$prefix"
	printf '%s\n' "$snapshot" >"${state_prefix}.snapshot"
	current_epoch >"${state_prefix}.time"
}

require_command() {
	if ! command -v "$1" >/dev/null 2>&1; then
		log "missing required command: $1"
		exit 1
	fi
}

require_executable() {
	if [ ! -x "$1" ]; then
		log "missing required executable: $1"
		exit 1
	fi
}

mqtt_enabled() {
	[ -n "${MQTT_HOST:-}" ]
}

mqtt_run_publish() {
	topic="$1"
	shift

	if output="$("$@" 2>&1)"; then
		return 0
	fi

	if [ -n "$output" ]; then
		log "mqtt publish failed for $topic: $output"
	else
		log "mqtt publish failed for $topic"
	fi

	return 0
}

mqtt_publish() {
	topic_suffix="$1"
	payload="$2"
	retain="${3:-false}"

	if ! mqtt_enabled; then
		return 0
	fi

	if ! command -v "$MQTT_PUB_BIN" >/dev/null 2>&1; then
		return 0
	fi

	set -- "$MQTT_PUB_BIN" \
		-h "$MQTT_HOST" \
		-p "$MQTT_PORT" \
		-t "$MQTT_TOPIC_PREFIX/$topic_suffix" \
		-i "$MQTT_CLIENT_ID" \
		-m "$payload"

	if [ "$retain" = "true" ]; then
		set -- "$@" -r
	fi

	if [ -n "${MQTT_USERNAME:-}" ]; then
		set -- "$@" -u "$MQTT_USERNAME"
	fi

	if [ -n "${MQTT_PASSWORD:-}" ]; then
		set -- "$@" -P "$MQTT_PASSWORD"
	fi

	mqtt_run_publish "$MQTT_TOPIC_PREFIX/$topic_suffix" "$@"
}

mqtt_publish_absolute() {
	topic="$1"
	payload="$2"
	retain="${3:-false}"

	if ! mqtt_enabled; then
		return 0
	fi

	if ! command -v "$MQTT_PUB_BIN" >/dev/null 2>&1; then
		return 0
	fi

	set -- "$MQTT_PUB_BIN" \
		-h "$MQTT_HOST" \
		-p "$MQTT_PORT" \
		-t "$topic" \
		-i "$MQTT_CLIENT_ID" \
		-m "$payload"

	if [ "$retain" = "true" ]; then
		set -- "$@" -r
	fi

	if [ -n "${MQTT_USERNAME:-}" ]; then
		set -- "$@" -u "$MQTT_USERNAME"
	fi

	if [ -n "${MQTT_PASSWORD:-}" ]; then
		set -- "$@" -P "$MQTT_PASSWORD"
	fi

	mqtt_run_publish "$topic" "$@"
}

persist_ups_snapshot() {
	status="$1"
	runtime="$2"
	charge="$3"
	ups_connected="$4"
	write_state_value "ups.status" "$status"
	write_state_value "ups.runtime" "$runtime"
	write_state_value "ups.charge" "$charge"
	write_state_value "ups.connected" "$ups_connected"
	write_state_value "ups.last_update_at" "$(current_timestamp)"
}

incident_status_value() {
	read_state_value "incident.status" "idle"
}

set_last_action() {
	action_name="$1"
	target_name="$2"
	result="$3"
	write_state_value "last_action" "$action_name"
	write_state_value "last_action_target" "$target_name"
	write_state_value "last_action_result" "$result"
	write_state_value "last_action_at" "$(current_timestamp)"
}

set_recovery_status() {
	recovery_status="$1"
	recovery_blocker="$2"
	recovery_elapsed_seconds="$3"
	write_state_value "recovery.status" "$recovery_status"
	write_state_value "recovery.blocker" "$recovery_blocker"
	write_state_value "recovery.elapsed_seconds" "$recovery_elapsed_seconds"
}

clear_incident_state() {
	write_state_value "incident.id" ""
	write_state_value "incident.status" "idle"
	write_state_value "incident.started_at" ""
	write_state_value "incident.ended_at" ""
	write_state_value "incident.power_restored_at" ""
	write_state_value "incident.duration_seconds" "0"
	write_state_value "incident.trigger_reason" ""
	write_state_value "incident.trigger_status" ""
	write_state_value "incident.trigger_runtime" ""
	write_state_value "incident.trigger_charge" ""
	clear_all_action_markers
	set_recovery_status "idle" "" "0"
}

store_last_completed_summary() {
	summary_completed_at="$(current_timestamp)"
	write_state_value "summary.id" "$(read_state_value "incident.id" "")"
	write_state_value "summary.status" "$(read_state_value "incident.status" "")"
	write_state_value "summary.started_at" "$(read_state_value "incident.started_at" "")"
	write_state_value "summary.ended_at" "$(read_state_value "incident.ended_at" "")"
	write_state_value "summary.power_restored_at" "$(read_state_value "incident.power_restored_at" "")"
	write_state_value "summary.duration_seconds" "$(read_state_value "incident.duration_seconds" "0")"
	write_state_value "summary.trigger_reason" "$(read_state_value "incident.trigger_reason" "")"
	write_state_value "summary.trigger_status" "$(read_state_value "incident.trigger_status" "")"
	write_state_value "summary.trigger_runtime" "$(read_state_value "incident.trigger_runtime" "")"
	write_state_value "summary.trigger_charge" "$(read_state_value "incident.trigger_charge" "")"
	write_state_value "summary.last_action" "$(read_state_value "last_action" "")"
	write_state_value "summary.last_action_target" "$(read_state_value "last_action_target" "")"
	write_state_value "summary.last_action_result" "$(read_state_value "last_action_result" "")"
	write_state_value "summary.last_action_at" "$(read_state_value "last_action_at" "")"
	write_state_value "summary.last_event" "$(read_state_value "last_event" "")"
	write_state_value "summary.last_event_at" "$(read_state_value "last_event_at" "")"
	write_state_value "summary.last_message" "$(read_state_value "last_message" "")"
	write_state_value "summary.recovery_status" "$(read_state_value "recovery.status" "")"
	write_state_value "summary.recovery_blocker" "$(read_state_value "recovery.blocker" "")"
	write_state_value "summary.completed_at" "$summary_completed_at"
}

normalize_startup_state() {
	incident_status="$(incident_status_value)"
	recovery_status="$(read_state_value "recovery.status" "idle")"

	case "$incident_status" in
		recovered)
			if [ "$recovery_status" = "idle" ]; then
				store_last_completed_summary
				clear_incident_state
				set_controller_phase "monitoring"
				log "migrated recovered incident state into last completed summary on startup"
			fi
			;;
		idle)
			set_recovery_status "idle" "" "0"
			;;
	esac
}

ha_discovery_enabled() {
	[ "$MQTT_ENABLE_HA_DISCOVERY" = "true" ]
}

discovery_republish_enabled() {
	case "$MQTT_DISCOVERY_REPUBLISH_INTERVAL_SECONDS" in
		''|*[!0-9]*) return 1 ;;
		0) return 1 ;;
		*) return 0 ;;
	esac
}

should_publish_discovery() {
	if ! ha_discovery_enabled; then
		return 1
	fi

	if [ ! -f "$STATE_DIR/ha_discovery.last_publish" ]; then
		return 0
	fi

	if ! discovery_republish_enabled; then
		return 1
	fi

	now="$(current_epoch)"
	last_publish="$(cat "$STATE_DIR/ha_discovery.last_publish" 2>/dev/null || printf '0')"
	case "$last_publish" in
		''|*[!0-9]*) return 0 ;;
	esac

	if [ $((now - last_publish)) -ge "$MQTT_DISCOVERY_REPUBLISH_INTERVAL_SECONDS" ]; then
		return 0
	fi

	return 1
}

record_discovery_publish() {
	current_epoch >"$STATE_DIR/ha_discovery.last_publish"
}

mqtt_publish_event() {
	event_name="$1"
	message="$2"
	event_status="$3"
	context_status="${4:-$(read_state_value "ups.status" "unknown")}"
	runtime="${5:-$(read_state_value "ups.runtime" "-1")}"
	charge="${6:-$(read_state_value "ups.charge" "")}"
	phase="${7:-$(read_state_value "controller.phase" "monitoring")}"
	reason="${8:-}"
	target_type="${9:-}"
	target_name="${10:-}"
	action_result="${11:-}"
	error_detail="${12:-}"
	timestamp="$(current_timestamp)"
	incident_id="$(read_state_value "incident.id" "")"
	incident_status="$(read_state_value "incident.status" "idle")"

	write_state_value "last_event" "$event_name"
	write_state_value "last_message" "$message"
	write_state_value "last_event_at" "$timestamp"

	if ! command -v "$JQ_BIN" >/dev/null 2>&1; then
		return 0
	fi

	payload="$($JQ_BIN -nc \
		--arg controller "$CONTROLLER_NAME" \
		--arg controller_version "$CONTROLLER_VERSION" \
		--arg mqtt_schema_version "$MQTT_SCHEMA_VERSION" \
		--arg timestamp "$timestamp" \
		--arg event "$event_name" \
		--arg message "$message" \
		--arg status "$event_status" \
		--arg ups_status "$context_status" \
		--arg runtime "$runtime" \
		--arg charge "$charge" \
		--arg phase "$phase" \
		--arg incident_id "$incident_id" \
		--arg incident_status "$incident_status" \
		--arg reason "$reason" \
		--arg target_type "$target_type" \
		--arg target_name "$target_name" \
		--arg action_result "$action_result" \
		--arg error_detail "$error_detail" \
		'{controller:$controller,controller_version:$controller_version,mqtt_schema_version:$mqtt_schema_version,timestamp:$timestamp,event:$event,message:$message,status:$status,ups_status:$ups_status,runtime:$runtime,charge:$charge,phase:$phase,incident_id:$incident_id,incident_status:$incident_status,reason:$reason,target_type:$target_type,target_name:$target_name,action_result:$action_result,error:$error_detail}')"
	mqtt_publish "event" "$payload" "false"
}

mqtt_publish_state() {
	status="$1"
	runtime="$2"
	charge="$3"
	mode="$4"
	ups_connected="$5"

	if ! command -v "$JQ_BIN" >/dev/null 2>&1; then
		return 0
	fi

	on_battery="false"
	if is_on_battery "$status"; then
		on_battery="true"
	fi

	phase="$(read_state_value "controller.phase" "monitoring")"
	recovery_status="$(read_state_value "recovery.status" "idle")"
	recovery_blocker="$(read_state_value "recovery.blocker" "")"
	recovery_elapsed_seconds="$(read_state_value "recovery.elapsed_seconds" "0")"
	recovery_elapsed_formatted="$(format_seconds_hms "$recovery_elapsed_seconds")"
	incident_id="$(read_state_value "incident.id" "")"
	incident_status="$(read_state_value "incident.status" "idle")"
	incident_started_at="$(read_state_value "incident.started_at" "")"
	incident_ended_at="$(read_state_value "incident.ended_at" "")"
	incident_power_restored_at="$(read_state_value "incident.power_restored_at" "")"
	incident_duration_seconds="$(read_state_value "incident.duration_seconds" "0")"
	incident_trigger_reason="$(read_state_value "incident.trigger_reason" "")"
	incident_trigger_status="$(read_state_value "incident.trigger_status" "")"
	incident_trigger_runtime="$(read_state_value "incident.trigger_runtime" "")"
	incident_trigger_charge="$(read_state_value "incident.trigger_charge" "")"
	last_action="$(read_state_value "last_action" "")"
	last_action_target="$(read_state_value "last_action_target" "")"
	last_action_result="$(read_state_value "last_action_result" "")"
	last_action_at="$(read_state_value "last_action_at" "")"
	last_event="$(read_state_value "last_event" "")"
	last_event_at="$(read_state_value "last_event_at" "")"
	last_message="$(read_state_value "last_message" "")"
	last_completed_id="$(read_state_value "summary.id" "")"
	last_completed_status="$(read_state_value "summary.status" "")"
	last_completed_started_at="$(read_state_value "summary.started_at" "")"
	last_completed_ended_at="$(read_state_value "summary.ended_at" "")"
	last_completed_power_restored_at="$(read_state_value "summary.power_restored_at" "")"
	last_completed_duration_seconds="$(read_state_value "summary.duration_seconds" "0")"
	last_completed_trigger_reason="$(read_state_value "summary.trigger_reason" "")"
	last_completed_trigger_status="$(read_state_value "summary.trigger_status" "")"
	last_completed_trigger_runtime="$(read_state_value "summary.trigger_runtime" "")"
	last_completed_trigger_charge="$(read_state_value "summary.trigger_charge" "")"
	last_completed_last_action="$(read_state_value "summary.last_action" "")"
	last_completed_last_action_target="$(read_state_value "summary.last_action_target" "")"
	last_completed_last_action_result="$(read_state_value "summary.last_action_result" "")"
	last_completed_last_action_at="$(read_state_value "summary.last_action_at" "")"
	last_completed_last_event="$(read_state_value "summary.last_event" "")"
	last_completed_last_event_at="$(read_state_value "summary.last_event_at" "")"
	last_completed_last_message="$(read_state_value "summary.last_message" "")"
	last_completed_recovery_status="$(read_state_value "summary.recovery_status" "")"
	last_completed_recovery_blocker="$(read_state_value "summary.recovery_blocker" "")"
	last_completed_at="$(read_state_value "summary.completed_at" "")"
	ceph_noout_set="$(marker_bool "ceph_noout")"
	talos_shutdown_started="$(marker_bool "talos_shutdown")"
	linux_shutdown_started="$(marker_bool "linux_shutdown")"
	proxmox_shutdown_started="$(marker_bool "proxmox_shutdown")"
	runtime_formatted="$(format_seconds_hms "$runtime")"
	incident_duration_formatted="$(format_seconds_hms "$incident_duration_seconds")"
	last_completed_duration_formatted="$(format_seconds_hms "$last_completed_duration_seconds")"
	incident_active="false"
	recovery_pending="false"
	failure_active="false"
	failure_code=""
	failure_message=""
	failure_severity=""
	failure_at=""

	case "$incident_status" in
		active|recovery_pending|timeout)
			incident_active="true"
			;;
	esac

	case "$recovery_status" in
		waiting|pending_boot|timeout)
			recovery_pending="true"
			;;
	esac

	if [ "$ups_connected" != "true" ]; then
		failure_active="true"
		failure_code="ups_unavailable"
		failure_message="unable to read UPS status"
		failure_severity="warning"
		failure_at="$last_event_at"
	elif [ "$incident_status" = "timeout" ] || [ "$recovery_status" = "timeout" ] || [ "$recovery_blocker" = "manual_review_required" ]; then
		failure_active="true"
		failure_code="recovery_timeout"
		failure_message="recovery timed out; manual review required"
		failure_severity="error"
		failure_at="$last_event_at"
	elif [ "$last_action_result" = "failed" ]; then
		failure_active="true"
		failure_code="action_failed"
		failure_message="action ${last_action:-unknown} failed for ${last_action_target:-unknown}"
		failure_severity="error"
		failure_at="$last_action_at"
	elif [ "$recovery_blocker" = "unset_noout_failed" ]; then
		failure_active="true"
		failure_code="recovery_blocked"
		failure_message="failed to unset ceph noout; retrying"
		failure_severity="warning"
		failure_at="$last_action_at"
	fi

	payload="$($JQ_BIN -nc \
		--arg controller "$CONTROLLER_NAME" \
		--arg controller_version "$CONTROLLER_VERSION" \
		--arg mqtt_schema_version "$MQTT_SCHEMA_VERSION" \
		--arg status "$status" \
		--arg runtime "$runtime" \
		--arg runtime_formatted "$runtime_formatted" \
		--arg charge "$charge" \
		--arg mode "$mode" \
		--arg phase "$phase" \
		--arg ups_connected "$ups_connected" \
		--arg on_battery "$on_battery" \
		--arg ceph_noout_set "$ceph_noout_set" \
		--arg talos_shutdown_started "$talos_shutdown_started" \
		--arg linux_shutdown_started "$linux_shutdown_started" \
		--arg proxmox_shutdown_started "$proxmox_shutdown_started" \
		--arg recovery_status "$recovery_status" \
		--arg recovery_blocker "$recovery_blocker" \
		--arg recovery_elapsed_seconds "$recovery_elapsed_seconds" \
		--arg recovery_elapsed_formatted "$recovery_elapsed_formatted" \
		--arg incident_id "$incident_id" \
		--arg incident_status "$incident_status" \
		--arg incident_active "$incident_active" \
		--arg recovery_pending "$recovery_pending" \
		--arg incident_started_at "$incident_started_at" \
		--arg incident_ended_at "$incident_ended_at" \
		--arg incident_power_restored_at "$incident_power_restored_at" \
		--arg incident_duration_seconds "$incident_duration_seconds" \
		--arg incident_duration_formatted "$incident_duration_formatted" \
		--arg incident_trigger_reason "$incident_trigger_reason" \
		--arg incident_trigger_status "$incident_trigger_status" \
		--arg incident_trigger_runtime "$incident_trigger_runtime" \
		--arg incident_trigger_charge "$incident_trigger_charge" \
		--arg last_action "$last_action" \
		--arg last_action_target "$last_action_target" \
		--arg last_action_result "$last_action_result" \
		--arg last_action_at "$last_action_at" \
		--arg last_event "$last_event" \
		--arg last_event_at "$last_event_at" \
		--arg last_message "$last_message" \
		--arg failure_active "$failure_active" \
		--arg failure_code "$failure_code" \
		--arg failure_message "$failure_message" \
		--arg failure_severity "$failure_severity" \
		--arg failure_at "$failure_at" \
		'{controller:$controller,controller_version:$controller_version,mqtt_schema_version:$mqtt_schema_version,status:$status,runtime:$runtime,runtime_formatted:$runtime_formatted,charge:$charge,mode:$mode,phase:$phase,ups_connected:($ups_connected == "true"),on_battery:($on_battery == "true"),ceph_noout_set:($ceph_noout_set == "true"),talos_shutdown_started:($talos_shutdown_started == "true"),linux_shutdown_started:($linux_shutdown_started == "true"),proxmox_shutdown_started:($proxmox_shutdown_started == "true"),recovery_status:$recovery_status,recovery_blocker:$recovery_blocker,recovery_elapsed_seconds:$recovery_elapsed_seconds,recovery_elapsed_formatted:$recovery_elapsed_formatted,incident_id:$incident_id,incident_status:$incident_status,incident_active:($incident_active == "true"),recovery_pending:($recovery_pending == "true"),incident_started_at:$incident_started_at,incident_ended_at:$incident_ended_at,incident_power_restored_at:$incident_power_restored_at,incident_duration_seconds:$incident_duration_seconds,incident_duration_formatted:$incident_duration_formatted,incident_trigger_reason:$incident_trigger_reason,incident_trigger_status:$incident_trigger_status,incident_trigger_runtime:$incident_trigger_runtime,incident_trigger_charge:$incident_trigger_charge,last_action:$last_action,last_action_target:$last_action_target,last_action_result:$last_action_result,last_action_at:$last_action_at,last_event:$last_event,last_event_at:$last_event_at,last_message:$last_message,failure_active:($failure_active == "true"),failure_code:$failure_code,failure_message:$failure_message,failure_severity:$failure_severity,failure_at:$failure_at}')"

	summary_payload="$($JQ_BIN -nc \
		--arg controller "$CONTROLLER_NAME" \
		--arg controller_version "$CONTROLLER_VERSION" \
		--arg mqtt_schema_version "$MQTT_SCHEMA_VERSION" \
		--arg last_completed_id "$last_completed_id" \
		--arg last_completed_status "$last_completed_status" \
		--arg last_completed_started_at "$last_completed_started_at" \
		--arg last_completed_ended_at "$last_completed_ended_at" \
		--arg last_completed_power_restored_at "$last_completed_power_restored_at" \
		--arg last_completed_duration_seconds "$last_completed_duration_seconds" \
		--arg last_completed_duration_formatted "$last_completed_duration_formatted" \
		--arg last_completed_trigger_reason "$last_completed_trigger_reason" \
		--arg last_completed_trigger_status "$last_completed_trigger_status" \
		--arg last_completed_trigger_runtime "$last_completed_trigger_runtime" \
		--arg last_completed_trigger_charge "$last_completed_trigger_charge" \
		--arg last_completed_last_action "$last_completed_last_action" \
		--arg last_completed_last_action_target "$last_completed_last_action_target" \
		--arg last_completed_last_action_result "$last_completed_last_action_result" \
		--arg last_completed_last_action_at "$last_completed_last_action_at" \
		--arg last_completed_last_event "$last_completed_last_event" \
		--arg last_completed_last_event_at "$last_completed_last_event_at" \
		--arg last_completed_last_message "$last_completed_last_message" \
		--arg last_completed_recovery_status "$last_completed_recovery_status" \
		--arg last_completed_recovery_blocker "$last_completed_recovery_blocker" \
		--arg last_completed_at "$last_completed_at" \
		'{controller:$controller,controller_version:$controller_version,mqtt_schema_version:$mqtt_schema_version,last_completed_id:$last_completed_id,last_completed_status:$last_completed_status,last_completed_started_at:$last_completed_started_at,last_completed_ended_at:$last_completed_ended_at,last_completed_power_restored_at:$last_completed_power_restored_at,last_completed_duration_seconds:$last_completed_duration_seconds,last_completed_duration_formatted:$last_completed_duration_formatted,last_completed_trigger_reason:$last_completed_trigger_reason,last_completed_trigger_status:$last_completed_trigger_status,last_completed_trigger_runtime:$last_completed_trigger_runtime,last_completed_trigger_charge:$last_completed_trigger_charge,last_completed_last_action:$last_completed_last_action,last_completed_last_action_target:$last_completed_last_action_target,last_completed_last_action_result:$last_completed_last_action_result,last_completed_last_action_at:$last_completed_last_action_at,last_completed_last_event:$last_completed_last_event,last_completed_last_event_at:$last_completed_last_event_at,last_completed_last_message:$last_completed_last_message,last_completed_recovery_status:$last_completed_recovery_status,last_completed_recovery_blocker:$last_completed_recovery_blocker,last_completed_at:$last_completed_at}')"

	mqtt_publish "state" "$payload" "$MQTT_RETAIN_STATUS"
	mqtt_publish "status" "$payload" "$MQTT_RETAIN_STATUS"
	mqtt_publish "summary" "$summary_payload" "true"
	mqtt_publish "incident" "$summary_payload" "true"
}

publish_homeassistant_discovery() {
	if ! ha_discovery_enabled; then
		return 0
	fi

	if ! command -v "$JQ_BIN" >/dev/null 2>&1; then
		return 0
	fi

	device_id="$(controller_device_id)"
	state_topic="$MQTT_TOPIC_PREFIX/state"
	summary_topic="$MQTT_TOPIC_PREFIX/summary"
	log "publishing Home Assistant discovery to $MQTT_DISCOVERY_PREFIX for $MQTT_TOPIC_PREFIX"
	device_json="$($JQ_BIN -nc \
		--arg identifier "$CONTROLLER_NAME" \
		--arg name "Shutdown Controller" \
		--arg manufacturer "FriedCircuits" \
		--arg model "Proxmox Shutdown Controller" \
		'{identifiers:[$identifier],name:$name,manufacturer:$manufacturer,model:$model}')"

	publish_discovery_config() {
		component="$1"
		object_id="$2"
		config_payload="$3"
		mqtt_publish_absolute "$MQTT_DISCOVERY_PREFIX/$component/$device_id/$object_id/config" "$config_payload" "true"
	}

	clear_discovery_config() {
		component="$1"
		object_id="$2"
		mqtt_publish_absolute "$MQTT_DISCOVERY_PREFIX/$component/$device_id/$object_id/config" "" "true"
	}

	stored_schema_version="$(read_state_value "ha_discovery.schema_version" "")"
	if [ "$stored_schema_version" != "$MQTT_DISCOVERY_SCHEMA_VERSION" ]; then
		log "clearing retained Home Assistant discovery configs for schema version $MQTT_DISCOVERY_SCHEMA_VERSION"
		clear_discovery_config "sensor" "ups_status"
		clear_discovery_config "sensor" "ups_runtime"
		clear_discovery_config "sensor" "ups_runtime_formatted"
		clear_discovery_config "sensor" "ups_charge"
		clear_discovery_config "sensor" "controller_version"
		clear_discovery_config "sensor" "mqtt_schema_version"
		clear_discovery_config "sensor" "controller_mode"
		clear_discovery_config "sensor" "controller_phase"
		clear_discovery_config "sensor" "failure_code"
		clear_discovery_config "sensor" "failure_message"
		clear_discovery_config "sensor" "failure_severity"
		clear_discovery_config "sensor" "failure_at"
		clear_discovery_config "sensor" "recovery_status"
		clear_discovery_config "sensor" "recovery_blocker"
		clear_discovery_config "sensor" "recovery_elapsed_seconds"
		clear_discovery_config "sensor" "recovery_elapsed_formatted"
		clear_discovery_config "sensor" "incident_status"
		clear_discovery_config "sensor" "incident_started_at"
		clear_discovery_config "sensor" "incident_ended_at"
		clear_discovery_config "sensor" "incident_power_restored_at"
		clear_discovery_config "sensor" "incident_duration_seconds"
		clear_discovery_config "sensor" "incident_duration_formatted"
		clear_discovery_config "sensor" "incident_trigger_reason"
		clear_discovery_config "sensor" "incident_trigger_runtime"
		clear_discovery_config "sensor" "incident_trigger_charge"
		clear_discovery_config "sensor" "last_action"
		clear_discovery_config "sensor" "last_action_target"
		clear_discovery_config "sensor" "last_action_result"
		clear_discovery_config "sensor" "last_action_at"
		clear_discovery_config "sensor" "last_event"
		clear_discovery_config "sensor" "last_event_at"
		clear_discovery_config "sensor" "last_message"
		clear_discovery_config "sensor" "last_completed_status"
		clear_discovery_config "sensor" "last_completed_started_at"
		clear_discovery_config "sensor" "last_completed_ended_at"
		clear_discovery_config "sensor" "last_completed_power_restored_at"
		clear_discovery_config "sensor" "last_completed_duration_formatted"
		clear_discovery_config "sensor" "last_completed_trigger_reason"
		clear_discovery_config "sensor" "last_completed_last_action"
		clear_discovery_config "sensor" "last_completed_at"
		clear_discovery_config "binary_sensor" "ups_connected"
		clear_discovery_config "binary_sensor" "on_battery"
		clear_discovery_config "binary_sensor" "incident_active"
		clear_discovery_config "binary_sensor" "failure_active"
		clear_discovery_config "binary_sensor" "recovery_pending"
		clear_discovery_config "binary_sensor" "ceph_noout_set"
		clear_discovery_config "binary_sensor" "talos_shutdown_started"
		clear_discovery_config "binary_sensor" "linux_shutdown_started"
		clear_discovery_config "binary_sensor" "proxmox_shutdown_started"
	fi

	publish_discovery_config "sensor" "ups_status" "$($JQ_BIN -nc --arg name "UPS Status" --arg object_id "ups_status" --arg default_entity_id "sensor.${device_id}_ups_status" --arg unique_id "${device_id}_ups_status" --arg state_topic "$state_topic" --arg icon "mdi:battery-medium" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.status }}",icon:$icon,device:$device}')"
	publish_discovery_config "sensor" "ups_runtime" "$($JQ_BIN -nc --arg name "UPS Runtime Seconds" --arg object_id "ups_runtime" --arg default_entity_id "sensor.${device_id}_ups_runtime" --arg unique_id "${device_id}_ups_runtime" --arg state_topic "$state_topic" --arg unit "s" --arg icon "mdi:timer-outline" --argjson enabled_by_default false --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.runtime | int(0) }}",unit_of_measurement:$unit,icon:$icon,enabled_by_default:$enabled_by_default,device:$device}')"
	publish_discovery_config "sensor" "ups_runtime_formatted" "$($JQ_BIN -nc --arg name "UPS Runtime" --arg object_id "ups_runtime_formatted" --arg default_entity_id "sensor.${device_id}_ups_runtime_formatted" --arg unique_id "${device_id}_ups_runtime_formatted" --arg state_topic "$state_topic" --arg icon "mdi:timer-outline" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.runtime_formatted }}",icon:$icon,device:$device}')"
	publish_discovery_config "sensor" "ups_charge" "$($JQ_BIN -nc --arg name "UPS Charge" --arg object_id "ups_charge" --arg default_entity_id "sensor.${device_id}_ups_charge" --arg unique_id "${device_id}_ups_charge" --arg state_topic "$state_topic" --arg unit "%" --arg icon "mdi:battery" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.charge | int(0) }}",unit_of_measurement:$unit,icon:$icon,device:$device}')"
	publish_discovery_config "sensor" "controller_version" "$($JQ_BIN -nc --arg name "Controller Version" --arg object_id "controller_version" --arg default_entity_id "sensor.${device_id}_controller_version" --arg unique_id "${device_id}_controller_version" --arg state_topic "$state_topic" --arg icon "mdi:source-branch" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.controller_version }}",icon:$icon,device:$device}')"
	publish_discovery_config "sensor" "mqtt_schema_version" "$($JQ_BIN -nc --arg name "MQTT Schema Version" --arg object_id "mqtt_schema_version" --arg default_entity_id "sensor.${device_id}_mqtt_schema_version" --arg unique_id "${device_id}_mqtt_schema_version" --arg state_topic "$state_topic" --arg icon "mdi:shape-outline" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.mqtt_schema_version }}",icon:$icon,device:$device}')"
	publish_discovery_config "sensor" "controller_mode" "$($JQ_BIN -nc --arg name "Mode" --arg object_id "mode" --arg default_entity_id "sensor.${device_id}_mode" --arg unique_id "${device_id}_controller_mode" --arg state_topic "$state_topic" --arg icon "mdi:transmission-tower" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.mode }}",icon:$icon,device:$device}')"
	publish_discovery_config "sensor" "controller_phase" "$($JQ_BIN -nc --arg name "Phase" --arg object_id "phase" --arg default_entity_id "sensor.${device_id}_phase" --arg unique_id "${device_id}_controller_phase" --arg state_topic "$state_topic" --arg icon "mdi:timeline-clock-outline" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.phase }}",icon:$icon,device:$device}')"
	publish_discovery_config "sensor" "failure_code" "$($JQ_BIN -nc --arg name "Failure Code" --arg object_id "failure_code" --arg default_entity_id "sensor.${device_id}_failure_code" --arg unique_id "${device_id}_failure_code" --arg state_topic "$state_topic" --arg icon "mdi:alert-circle-outline" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.failure_code }}",icon:$icon,device:$device}')"
	publish_discovery_config "sensor" "failure_message" "$($JQ_BIN -nc --arg name "Failure Message" --arg object_id "failure_message" --arg default_entity_id "sensor.${device_id}_failure_message" --arg unique_id "${device_id}_failure_message" --arg state_topic "$state_topic" --arg icon "mdi:message-alert-outline" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.failure_message }}",icon:$icon,device:$device}')"
	publish_discovery_config "sensor" "failure_severity" "$($JQ_BIN -nc --arg name "Failure Severity" --arg object_id "failure_severity" --arg default_entity_id "sensor.${device_id}_failure_severity" --arg unique_id "${device_id}_failure_severity" --arg state_topic "$state_topic" --arg icon "mdi:alert-decagram-outline" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.failure_severity }}",icon:$icon,device:$device}')"
	publish_discovery_config "sensor" "failure_at" "$($JQ_BIN -nc --arg name "Failure At" --arg object_id "failure_at" --arg default_entity_id "sensor.${device_id}_failure_at" --arg unique_id "${device_id}_failure_at" --arg state_topic "$state_topic" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.failure_at }}",device_class:"timestamp",device:$device}')"
	publish_discovery_config "sensor" "recovery_status" "$($JQ_BIN -nc --arg name "Recovery Status" --arg object_id "recovery_status" --arg default_entity_id "sensor.${device_id}_recovery_status" --arg unique_id "${device_id}_recovery_status" --arg state_topic "$state_topic" --arg icon "mdi:restore-alert" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.recovery_status }}",icon:$icon,device:$device}')"
	publish_discovery_config "sensor" "recovery_blocker" "$($JQ_BIN -nc --arg name "Recovery Blocker" --arg object_id "recovery_blocker" --arg default_entity_id "sensor.${device_id}_recovery_blocker" --arg unique_id "${device_id}_recovery_blocker" --arg state_topic "$state_topic" --arg icon "mdi:progress-alert" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.recovery_blocker }}",icon:$icon,device:$device}')"
	publish_discovery_config "sensor" "recovery_elapsed_seconds" "$($JQ_BIN -nc --arg name "Recovery Elapsed Seconds" --arg object_id "recovery_elapsed_seconds" --arg default_entity_id "sensor.${device_id}_recovery_elapsed_seconds" --arg unique_id "${device_id}_recovery_elapsed_seconds" --arg state_topic "$state_topic" --arg unit "s" --arg icon "mdi:clock-alert-outline" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.recovery_elapsed_seconds | int(0) }}",unit_of_measurement:$unit,icon:$icon,device:$device}')"
	publish_discovery_config "sensor" "recovery_elapsed_formatted" "$($JQ_BIN -nc --arg name "Recovery Elapsed" --arg object_id "recovery_elapsed_formatted" --arg default_entity_id "sensor.${device_id}_recovery_elapsed_formatted" --arg unique_id "${device_id}_recovery_elapsed_formatted" --arg state_topic "$state_topic" --arg icon "mdi:clock-alert-outline" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.recovery_elapsed_formatted }}",icon:$icon,device:$device}')"
	publish_discovery_config "sensor" "incident_status" "$($JQ_BIN -nc --arg name "Incident Status" --arg object_id "incident_status" --arg default_entity_id "sensor.${device_id}_incident_status" --arg unique_id "${device_id}_incident_status" --arg state_topic "$state_topic" --arg icon "mdi:alert-circle-check-outline" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.incident_status }}",icon:$icon,device:$device}')"
	publish_discovery_config "sensor" "incident_started_at" "$($JQ_BIN -nc --arg name "Incident Started" --arg object_id "incident_started_at" --arg default_entity_id "sensor.${device_id}_incident_started_at" --arg unique_id "${device_id}_incident_started_at" --arg state_topic "$state_topic" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.incident_started_at }}",device_class:"timestamp",device:$device}')"
	publish_discovery_config "sensor" "incident_ended_at" "$($JQ_BIN -nc --arg name "Incident Ended" --arg object_id "incident_ended_at" --arg default_entity_id "sensor.${device_id}_incident_ended_at" --arg unique_id "${device_id}_incident_ended_at" --arg state_topic "$state_topic" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.incident_ended_at }}",device_class:"timestamp",device:$device}')"
	publish_discovery_config "sensor" "incident_power_restored_at" "$($JQ_BIN -nc --arg name "Power Restored" --arg object_id "incident_power_restored_at" --arg default_entity_id "sensor.${device_id}_incident_power_restored_at" --arg unique_id "${device_id}_incident_power_restored_at" --arg state_topic "$state_topic" --argjson device "$device_json" '{name:$name,object_id:$object_id,default_entity_id:$default_entity_id,unique_id:$unique_id,state_topic:$state_topic,value_template:"{{ value_json.incident_power_restored_at }}",device_class:"timestamp",device:$device}')"
