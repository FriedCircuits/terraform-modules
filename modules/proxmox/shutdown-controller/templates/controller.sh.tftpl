log_startup_summary() {
	log "startup: dry_run=$DRY_RUN poll_interval_seconds=$POLL_INTERVAL_SECONDS nut_target=$NUT_TARGET"
	log "startup: status_log_interval_seconds=$STATUS_LOG_INTERVAL_SECONDS"
	log "startup: thresholds noout=$NOOUT_MIN_RUNTIME_SECONDS talos=$TALOS_SHUTDOWN_MIN_RUNTIME_SECONDS linux=$LINUX_SHUTDOWN_MIN_RUNTIME_SECONDS proxmox=$PROXMOX_SHUTDOWN_MIN_RUNTIME_SECONDS"
	log "startup: talos_nodes=${TALOS_NODES:-} linux_shutdown_targets_b64_set=$([ -n "${LINUX_SHUTDOWN_TARGETS_B64:-}" ] && printf true || printf false) proxmox_nodes=${PROXMOX_NODES:-}"

	if [ -n "${NUT_USERNAME:-}" ] && [ -n "${NUT_PASSWORD:-}" ]; then
		log "startup: nut_auth=enabled"
	else
		log "startup: nut_auth=disabled"
	fi

	if [ -n "${PVE_API_ENDPOINT:-}" ] && [ -n "${PVE_API_USER:-}" ]; then
		log "startup: proxmox_api=enabled endpoint=$PVE_API_ENDPOINT"
	else
		log "startup: proxmox_api=disabled"
	fi

	if ha_discovery_enabled; then
		log "startup: mqtt_discovery=enabled prefix=$MQTT_DISCOVERY_PREFIX republish_interval_seconds=$MQTT_DISCOVERY_REPUBLISH_INTERVAL_SECONDS"
	else
		log "startup: mqtt_discovery=disabled"
	fi
}

log_status_summary() {
	mode="$1"
	status="$2"
	runtime="$3"
	charge="$4"
	prefix="$5"
	if [ "$prefix" = "battery" ]; then
		snapshot="$(battery_status_snapshot "$status" "$runtime" "$charge")"
	else
		snapshot="$(normal_status_snapshot "$status")"
	fi

	if should_log_status "$snapshot" "$prefix"; then
		log "$mode: status=$status runtime=$runtime charge=$charge phase=$(read_state_value "controller.phase" "monitoring") incident_status=$(read_state_value "incident.status" "idle")"
		record_status_log "$snapshot" "$prefix"
	fi
	mqtt_publish_state "$status" "$runtime" "$charge" "$prefix" "true"
}

upsc_field() {
	field_name="$1"
	"$UPSC_BIN" "$NUT_TARGET" 2>/dev/null | awk -F': *' -v key="$field_name" '$1 == key {print $2; exit}'
}

authenticated_nut_field() {
	field_name="$1"
	python3 - "$NUT_SERVER_HOST" "${NUT_SERVER_PORT:-3493}" "$NUT_UPS_NAME" "$field_name" "$NUT_USERNAME" "$NUT_PASSWORD" <<'PY'
import socket
import sys

host, port, ups_name, field_name, username, password = sys.argv[1:7]


def recv_line(sock):
	data = b""
	while not data.endswith(b"\n"):
		chunk = sock.recv(4096)
		if not chunk:
			raise RuntimeError("connection closed")
		data += chunk
	return data.decode().strip()


def send_command(sock, *parts):
	command = " ".join(parts) + "\n"
	sock.sendall(command.encode())
	return recv_line(sock)


def parse_var_response(response):
	parts = response.split(" ", 3)
	if len(parts) != 4 or parts[0] != "VAR":
		raise RuntimeError(response)
	value = parts[3]
	if len(value) >= 2 and value[0] == '"' and value[-1] == '"':
		value = value[1:-1]
	return value


with socket.create_connection((host, int(port)), timeout=5) as sock:
	response = send_command(sock, "USERNAME", username)
	if not response.startswith("OK"):
		raise RuntimeError(response)

	response = send_command(sock, "PASSWORD", password)
	if not response.startswith("OK"):
		raise RuntimeError(response)

	response = send_command(sock, "GET", "VAR", ups_name, field_name)
	print(parse_var_response(response))
PY
}

nut_field() {
	field_name="$1"

	if [ -n "${NUT_USERNAME:-}" ] && [ -n "${NUT_PASSWORD:-}" ]; then
		authenticated_nut_field "$field_name" 2>/dev/null || true
		return 0
	fi

	upsc_field "$field_name" || true
}

runtime_seconds() {
	runtime_value="$(nut_field battery.runtime)"
	case "$runtime_value" in
		''|*[!0-9]*) printf '%s\n' "-1" ;;
		*) printf '%s\n' "$runtime_value" ;;
	esac
}

ups_status() {
	nut_field ups.status
}

is_on_battery() {
	case "$1" in
		*OB*|*LB*|*FSD*) return 0 ;;
		*) return 1 ;;
	esac
}

open_incident_if_needed() {
	status="$1"
	runtime="$2"
	charge="$3"
	if [ "$(incident_status_value)" = "active" ]; then
		return 1
	fi

	incident_id="$(date -u +%Y%m%dT%H%M%SZ)"
	timestamp="$(current_timestamp)"
	reset_incident_state_for_new_event
	write_state_value "incident.id" "$incident_id"
	write_state_value "incident.status" "active"
	write_state_value "incident.started_at" "$timestamp"
	write_state_value "incident.trigger_reason" "ups_on_battery"
	write_state_value "incident.trigger_status" "$status"
	write_state_value "incident.trigger_runtime" "$runtime"
	write_state_value "incident.trigger_charge" "$charge"
	set_controller_phase "on_battery"
	set_recovery_status "idle" "" "0"
	log "incident opened: id=$incident_id status=$status runtime=$runtime charge=$charge"
	mqtt_publish_event "power_loss_detected" "UPS entered battery mode" "warning" "$status" "$runtime" "$charge" "on_battery" "ups_on_battery"
	return 0
}

transition_battery_stage() {
	status="$1"
	runtime="$2"
	charge="$3"
	stage="$(battery_action_stage "$runtime")"
	previous_stage="$(read_state_value "battery.stage" "")"
	phase="$(controller_phase_for_status "$status" "$runtime")"
	write_state_value "battery.stage" "$stage"
	set_controller_phase "$phase"

	if [ "$stage" = "$previous_stage" ]; then
		return 0
	fi

	case "$stage" in
		monitoring|unknown)
			return 0
			;;
	esac

	reason="runtime threshold crossed for $stage at ${runtime}s"
	write_state_value "incident.trigger_reason" "$reason"
	write_state_value "incident.trigger_status" "$status"
	write_state_value "incident.trigger_runtime" "$runtime"
	write_state_value "incident.trigger_charge" "$charge"
	log "threshold crossed: stage=$stage runtime=$runtime charge=$charge"
	mqtt_publish_event "threshold_crossed" "$reason" "warning" "$status" "$runtime" "$charge" "$phase" "$reason" "threshold" "$stage"
}

handle_line_power_restored() {
	status="$1"
	runtime="$2"
	charge="$3"
	incident_status="$(incident_status_value)"
	case "$incident_status" in
		active) ;;
		*) return 0 ;;
	esac

	timestamp="$(current_timestamp)"
	now_epoch="$(current_epoch)"
	started_epoch="$(date -d "$(read_state_value "incident.started_at" "$timestamp")" +%s 2>/dev/null || printf '%s' "$now_epoch")"
	duration_seconds="$(duration_between_epochs "$started_epoch" "$now_epoch")"
	write_state_value "incident.power_restored_at" "$timestamp"
	write_state_value "incident.ended_at" "$timestamp"
	write_state_value "incident.duration_seconds" "$duration_seconds"

	if [ "$(marker_bool "ceph_noout")" = "true" ]; then
		write_state_value "incident.status" "recovery_pending"
		set_controller_phase "power_restored_recovery_pending"
		set_recovery_status "pending_boot" "waiting_for_controller_reboot" "0"
		clear_shutdown_markers
		log "line power restored; recovery is pending because ceph noout remains set"
		mqtt_publish_event "line_power_restored" "Line power restored; recovery pending" "ok" "$status" "$runtime" "$charge" "power_restored_recovery_pending" "ceph_noout_remains_set"
		return 0
	fi

	write_state_value "incident.status" "recovered"
	set_controller_phase "monitoring"
	set_recovery_status "idle" "" "0"
	clear_all_action_markers
	log "line power restored; incident closed after ${duration_seconds}s"
	mqtt_publish_event "line_power_restored" "Line power restored" "ok" "$status" "$runtime" "$charge" "monitoring" "line_power_restored"
	mqtt_publish_event "incident_closed" "Power incident closed" "ok" "$status" "$runtime" "$charge" "monitoring" "incident_closed"
	store_last_completed_summary
	clear_incident_state
}

run_once() {
	name="$1"
	shift

	marker="$STATE_DIR/$name.done"
	if [ -f "$marker" ]; then
		return 0
	fi

	if "$@"; then
		: >"$marker"
		return 0
	fi

	return 1
}

run_action() {
	label="$1"
	event_name="$2"
	target_type="$3"
	target_name="$4"
	status="$5"
	runtime="$6"
	charge="$7"
	phase="$8"
	shift 8

	if [ "$DRY_RUN" = "true" ]; then
		log "dry-run: $label"
		set_last_action "$event_name" "$target_name" "dry-run"
		mqtt_publish_event "$event_name" "$label" "dry-run" "$status" "$runtime" "$charge" "$phase" "$label" "$target_type" "$target_name" "dry-run"
		return 0
	fi

	log "running: $label"
	mqtt_publish_event "$event_name" "$label" "running" "$status" "$runtime" "$charge" "$phase" "$label" "$target_type" "$target_name" "running"
	if "$@"; then
		set_last_action "$event_name" "$target_name" "ok"
		mqtt_publish_event "${event_name}_complete" "$label complete" "ok" "$status" "$runtime" "$charge" "$phase" "$label" "$target_type" "$target_name" "ok"
		return 0
	fi

	exit_code="$?"
	set_last_action "$event_name" "$target_name" "failed"
	log "failed: $label exit_code=$exit_code"
	mqtt_publish_event "${event_name}_failed" "$label failed" "error" "$status" "$runtime" "$charge" "$phase" "$label" "$target_type" "$target_name" "failed" "exit_code=$exit_code"
	return "$exit_code"
}

set_ceph_noout() {
	status="$1"
	runtime="$2"
	charge="$3"
	require_executable "$KUBECTL_BIN"
	run_action "set ceph noout" "ceph_noout_set" "ceph" "cluster" "$status" "$runtime" "$charge" "ceph_noout" "$KUBECTL_BIN" -n "$CEPH_NAMESPACE" exec "deploy/$CEPH_TOOLS_DEPLOYMENT" -- ceph osd set noout
}

shutdown_talos_nodes() {
	status="$1"
	runtime="$2"
	charge="$3"
	nodes="$(split_csv "${TALOS_NODES:-}")"
	if [ -z "$nodes" ]; then
		log "no TALOS_NODES configured"
		return 0
	fi

	require_executable "$TALOSCTL_BIN"
	printf '%s\n' "$nodes" | while IFS= read -r node; do
		run_action "shutdown Talos node $node" "talos_shutdown_started" "talos" "$node" "$status" "$runtime" "$charge" "talos_shutdown" "$TALOSCTL_BIN" -n "$node" shutdown --wait=false
	done
}

linux_shutdown_targets_json() {
	if [ -z "$LINUX_SHUTDOWN_TARGETS_B64" ]; then
		printf '%s\n' '[]'
		return 0
	fi

	decoded_targets="$(printf '%s' "$LINUX_SHUTDOWN_TARGETS_B64" | base64 -d 2>/dev/null || true)"
	if [ -z "$decoded_targets" ]; then
		printf '%s\n' '[]'
		return 0
	fi

	printf '%s\n' "$decoded_targets"
}

linux_shutdown_over_ssh() {
	host="$1"
	user="$2"
	port="$3"
	remote_command="$4"

	set -- "$SSH_BIN" \
		-i "$LINUX_SHUTDOWN_SSH_KEY_PATH" \
		-o BatchMode=yes \
		-o IdentitiesOnly=yes \
		-o StrictHostKeyChecking="$LINUX_SHUTDOWN_SSH_STRICT_HOST_KEY_CHECKING" \
		-o UserKnownHostsFile="$LINUX_SHUTDOWN_SSH_KNOWN_HOSTS_PATH" \
		-p "$port" \
		"$user@$host" \
		"$remote_command"

	"$@"
}

shutdown_linux_nodes() {
	status="$1"
	runtime="$2"
	charge="$3"
	targets_json="$(linux_shutdown_targets_json)"
	if [ "$targets_json" = '[]' ]; then
		log "no LINUX_SHUTDOWN_TARGETS configured"
		return 0
	fi

	require_executable "$SSH_BIN"
	require_command "$JQ_BIN"

	if [ ! -f "$LINUX_SHUTDOWN_SSH_KEY_PATH" ]; then
		log "Linux shutdown SSH key is not configured; skipping Linux shutdown targets"
		return 0
	fi

	printf '%s' "$targets_json" | "$JQ_BIN" -cr '.[] | @base64' | while IFS= read -r target_b64; do
		target_json="$(printf '%s' "$target_b64" | base64 -d)"
		name="$(printf '%s' "$target_json" | "$JQ_BIN" -r '.name // empty')"
		host="$(printf '%s' "$target_json" | "$JQ_BIN" -r '.host')"
		user="$(printf '%s' "$target_json" | "$JQ_BIN" -r --arg default_user "$LINUX_SHUTDOWN_SSH_USER" '.user // $default_user')"
		port="$(printf '%s' "$target_json" | "$JQ_BIN" -r --argjson default_port "$LINUX_SHUTDOWN_SSH_PORT" '.port // $default_port')"
		remote_command="$(printf '%s' "$target_json" | "$JQ_BIN" -r '.command // "sudo systemctl poweroff"')"
		label="$host"
		if [ -n "$name" ]; then
			label="$name"
		fi
		run_action "shutdown Linux node $label" "linux_shutdown_started" "linux" "$label" "$status" "$runtime" "$charge" "linux_shutdown" linux_shutdown_over_ssh "$host" "$user" "$port" "$remote_command"
	done
}

pve_api_request() {
	method="$1"
	path="$2"
	data="$3"

	if [ -n "${PVE_API_TOKEN_ID:-}" ] && [ -n "${PVE_API_TOKEN_SECRET:-}" ]; then
		curl_opts="-fsS"
		if [ "${PVE_API_TLS_INSECURE:-false}" = "true" ]; then
			curl_opts="$curl_opts -k"
		fi

		# shellcheck disable=SC2086
		curl $curl_opts -X "$method" \
			-H "Authorization: PVEAPIToken=${PVE_API_USER}!${PVE_API_TOKEN_ID}=${PVE_API_TOKEN_SECRET}" \
			-d "$data" \
			"$PVE_API_ENDPOINT$path" >/dev/null
		return 0
	fi

	if [ -n "${PVE_API_PASSWORD:-}" ]; then
		curl_opts="-fsS"
		if [ "${PVE_API_TLS_INSECURE:-false}" = "true" ]; then
			curl_opts="$curl_opts -k"
		fi

		# shellcheck disable=SC2086
		auth_json="$(curl $curl_opts -X POST \
			-d "username=$PVE_API_USER" \
			--data-urlencode "password=$PVE_API_PASSWORD" \
			"$PVE_API_ENDPOINT/access/ticket")"

		require_command "$JQ_BIN"
		ticket="$(printf '%s' "$auth_json" | "$JQ_BIN" -r '.data.ticket')"
		csrf="$(printf '%s' "$auth_json" | "$JQ_BIN" -r '.data.CSRFPreventionToken')"

		# shellcheck disable=SC2086
		curl $curl_opts -X "$method" \
			-H "CSRFPreventionToken: $csrf" \
			-H "Cookie: PVEAuthCookie=$ticket" \
			-d "$data" \
			"$PVE_API_ENDPOINT$path" >/dev/null
		return 0
	fi

	log "Proxmox API credentials are not configured"
	return 1
}

shutdown_proxmox_nodes() {
	status="$1"
	runtime="$2"
	charge="$3"
	if [ -z "${PVE_API_ENDPOINT:-}" ] || [ -z "${PVE_API_USER:-}" ]; then
		log "PVE_API_* is not configured; skipping Proxmox shutdown"
		return 0
	fi

	nodes="$(split_csv "${PROXMOX_NODES:-}")"
	if [ -z "$nodes" ]; then
		log "no PROXMOX_NODES configured"
		return 0
	fi

	printf '%s\n' "$nodes" | while IFS= read -r node; do
		run_action "shutdown Proxmox node $node" "proxmox_shutdown_started" "proxmox" "$node" "$status" "$runtime" "$charge" "proxmox_shutdown" pve_api_request POST "/nodes/$node/status" "command=shutdown"
	done
}

handle_battery_event() {
	status="$1"
	runtime="$2"
	charge="$3"
	persist_ups_snapshot "$status" "$runtime" "$charge" "true"
	open_incident_if_needed "$status" "$runtime" "$charge" || true
	transition_battery_stage "$status" "$runtime" "$charge"
	log_status_summary "UPS on battery" "$status" "$runtime" "$charge" "battery"

	if [ "$runtime" -lt 0 ]; then
		log "battery.runtime is unavailable; skipping threshold-based actions"
		mqtt_publish_event "battery_runtime_unavailable" "battery.runtime is unavailable; skipping threshold-based actions" "warning" "$status" "$runtime" "$charge" "on_battery" "battery_runtime_unavailable"
		mqtt_publish_state "$status" "$runtime" "$charge" "battery" "true"
		return 0
	fi

	if [ "$runtime" -le "$NOOUT_MIN_RUNTIME_SECONDS" ]; then
		run_once ceph_noout set_ceph_noout "$status" "$runtime" "$charge" || true
	fi

	if [ "$runtime" -le "$TALOS_SHUTDOWN_MIN_RUNTIME_SECONDS" ]; then
		run_once talos_shutdown shutdown_talos_nodes "$status" "$runtime" "$charge" || true
	fi

	if [ "$runtime" -le "$LINUX_SHUTDOWN_MIN_RUNTIME_SECONDS" ]; then
		run_once linux_shutdown shutdown_linux_nodes "$status" "$runtime" "$charge" || true
	fi

	if [ "$runtime" -le "$PROXMOX_SHUTDOWN_MIN_RUNTIME_SECONDS" ]; then
		run_once proxmox_shutdown shutdown_proxmox_nodes "$status" "$runtime" "$charge" || true
	fi
}

handle_normal_status() {
	status="$1"
	runtime="$2"
	charge="$3"
	persist_ups_snapshot "$status" "$runtime" "$charge" "true"
	handle_line_power_restored "$status" "$runtime" "$charge"
	set_controller_phase "$(controller_phase_for_status "$status" "$runtime")"
	log_status_summary "UPS status" "$status" "$runtime" "$charge" "normal"
}

main() {
	if [ -z "$NUT_TARGET" ]; then
		log "NUT_TARGET is not configured"
		exit 1
	fi

	if [ -n "${NUT_USERNAME:-}" ] || [ -n "${NUT_PASSWORD:-}" ]; then
		require_command python3
		if [ -z "${NUT_SERVER_HOST:-}" ] || [ -z "${NUT_UPS_NAME:-}" ]; then
			log "NUT_SERVER_HOST and NUT_UPS_NAME are required for authenticated NUT polling"
			exit 1
		fi
	else
		require_command "$UPSC_BIN"
	fi

	if [ -z "$(read_state_value "controller.phase" "")" ]; then
		set_controller_phase "monitoring"
	fi

	normalize_startup_state

	log_startup_summary
	publish_homeassistant_discovery
	mqtt_publish_event "startup" "shutdown controller started" "ok" "unknown" "-1" "" "monitoring" "controller_startup"
	log "starting controller loop for $NUT_TARGET"

	while true; do
		status="$(ups_status)"
		runtime="$(runtime_seconds)"
		charge="$(nut_field battery.charge)"

		if should_publish_discovery; then
			publish_homeassistant_discovery
		fi

		if [ -z "$status" ]; then
			persist_ups_snapshot "unknown" "-1" "" "false"
			set_controller_phase "ups_disconnected"
			log "unable to read UPS status from $NUT_TARGET"
			mqtt_publish_event "ups_unavailable" "unable to read UPS status" "warning" "unknown" "-1" "$charge" "ups_disconnected" "ups_unavailable"
			mqtt_publish_state "unknown" "-1" "" "disconnected" "false"
			sleep "$POLL_INTERVAL_SECONDS"
			continue
		fi

		if is_on_battery "$status"; then
			handle_battery_event "$status" "$runtime" "$charge"
		else
			handle_normal_status "$status" "$runtime" "$charge"
		fi

		sleep "$POLL_INTERVAL_SECONDS"
	done
}

main "$@"
